      "config" : {
        "dialog" : "com.axonivy.connector.imb.mq.ManualApproval:start(com.axonivy.connector.imb.mq.model.TaskDetail)",
        "call" : {
          "map" : {
            "param.taskDetail" : "in.taskDetail"
          }
        },
        "output" : {
          "map" : {
            "out" : "in",
            "out.approval" : "result.approval"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 496, "y" : 192 }
      },
      "connect" : [
        { "id" : "f13", "to" : "f14" }
      ]
    }, {
      "id" : "f14",
      "type" : "Script",
      "name" : "Custom Fields",
      "config" : {
        "output" : {
          "code" : [
            "import ch.ivyteam.ivy.workflow.ITask;",
            "ITask task = ivy.task;",
            "",
            "ivy.log.warn(\"Custom fields::approval: \" + in.approval);",
            "task.customFields().stringField(\"customerId\").set(out.taskDetail.getCustomerId());",
            "if (out.taskDetail.getLoanApplication() != null && out.taskDetail.getLoanApplication().getApplicant() != null && out.taskDetail.getLoanApplication().getApplicant() != null && out.taskDetail.getLoanApplication().getApplicant().getName() != null) {",
            "  task.customFields().stringField(\"firstName\").set(out.taskDetail.getLoanApplication().getApplicant().name.first);",
            "  task.customFields().stringField(\"lastName\").set(out.taskDetail.getLoanApplication().getApplicant().name.last);",
            "}",
            "if (in.taskDetail.autoApproval) {",
            "  task.customFields().stringField(\"decisionType\").set( \"AUTO\");",
            "  task.customFields().stringField(\"decision\").set(\"CONFIRM\");",
            "} else {",
            "  task.customFields().stringField(\"decisionType\").set( \"MANUAL\");",
            "  task.customFields().stringField(\"decision\").set(in.approval);",
            "}"
          ]
        }
      },
